{
  "name": "humming-agent",
  "version": "0.2.0",
  "description": "Humming Agent: a lightweight, file-driven relay agent for delegating chat requests to local ACP agents",
  "type": "module",
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "humming": "./dist/bin/humming.js",
    "humming-lifecycle-coordinator": "./dist/bin/lifecycle-coordinator.js",
    "humming-mock": "./dist/bin/mock-agent.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/chmod-bins.mjs",
    "prepare": "npm run build",
    "start": "node dist/bin/humming.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check ."
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@larksuiteoapi/node-sdk": "^1.65.0",
    "@reduxjs/toolkit": "^2.12.0",
    "commander": "^15.0.0",
    "marked": "^18.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangmingliang-ms/humming.git"
  },
  "license": "MIT",
  "keywords": [
    "humming-agent",
    "humming",
    "feishu",
    "lark",
    "acp",
    "agent-client-protocol",
    "ai-agent",
    "relay",
    "delegate"
  ]
}
